# Single source of truth for versions referenced by both
# .github/workflows/development.yaml and .github/workflows/release.yaml.
# Each workflow loads this file with `cat .github/versions.env >>
# $GITHUB_ENV` so the values become available as ${{ env.X }}.
#
# Bump these in a single PR; reviewers see the version diff and the
# resulting CI run side by side. Dependabot can target this file
# directly when version-bumping is automated.

# go-jsonschema fork tag that aapi-codegen is built against. Match the
# local `replace github.com/atombender/go-jsonschema => ../go-jsonschema`
# directive in go.mod when bumping.
AAPI_GJS_VERSION=v0.24.0-rc.1

# Hard-coded so a fork rename doesn't accidentally swap out the
# patched build.
AAPI_GJS_REPO=plheide/go-jsonschema

# Go toolchain version used by CI and the release pipeline.
GO_VERSION=1.26.2

# golangci-lint version used by CI.
GOLANGCI_LINT_VERSION=v2.12.2
